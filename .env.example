# Copy to .env and fill in real values: cp .env.example .env
# .env is gitignored; .env.example is the tracked template.

# JWT signing secret. There is NO code default (the app fails fast if this is
# absent or blank), so compose MUST supply it. Use a long random string.
APP_JWT_SECRET=

# MySQL credentials / database for the bundled db service.
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=ideophone_arena

# Host path to the resolved stimulus directory that contains audio/ (and the
# other media). It is bind-mounted read-only into the api container at
# /srv/stimuli. This is environment-specific because the api and frontend repos
# live at an environment-specific relative location.
# Example (this dev machine): /code/js/ideophone-arena-web/dist/stimuli
STIMULI_HOST_DIR=
